// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  displayName  String?
  sessions     Session[]
  workouts     Workout[]
  exercises    Exercise[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Session {
  id          String   @id @default(uuid())
  name        String
  description String?
  workoutId   String?
  status      SessionStatus @default(INITIATED)
  workout     Workout? @relation(fields: [workoutId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  tasks       Task[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id                     String     @id @default(uuid())
  name                   String
  description            String?
  plannedDurationSeconds Int
  actualDurationSeconds  Int?
  status                 TaskStatus @default(PENDING)
  notes                  String?
  order                  Int
  exerciseId             String
  exercise               Exercise   @relation(fields: [exerciseId], references: [id])
  sessionId              String
  session                Session    @relation(fields: [sessionId], references: [id])
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
}

model Workout {
  id          String        @id @default(uuid())
  name        String
  description String?
  steps       WorkoutStep[]
  sessions    Session[]
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Exercise {
  id                  String        @id @default(uuid())
  name                String
  description         String
  descriptionRichText Json?
  timeboxSeconds      Int
  userId              String
  user                User          @relation(fields: [userId], references: [id])
  resources           Resource[]
  tasks               Task[]
  workoutSteps        WorkoutStep[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

enum SessionStatus {
  INITIATED
  IN_PROGRESS
  DONE
  USER_BREAK
  CANCELLED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  SKIPPED
}

model WorkoutStep {
  id                     String   @id @default(uuid())
  workoutId              String
  workout                Workout  @relation(fields: [workoutId], references: [id])
  exerciseId             String
  exercise               Exercise @relation(fields: [exerciseId], references: [id])
  order                  Int
  plannedDurationSeconds Int?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@unique([workoutId, order])
}

enum ResourceType {
  LINK
  DOCUMENT
  VIDEO
  IMAGE
  AUDIOFILE
}

model Resource {
  id         String       @id @default(uuid())
  type       ResourceType
  title      String?
  url        String
  exerciseId String
  exercise   Exercise     @relation(fields: [exerciseId], references: [id])
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}
